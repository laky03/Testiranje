@model SplitSync.Models.NoviRacunViewModel
@using SplitSync.Models

@{
    ViewData["Title"] = "Novi račun";
    var clanoviSrc = Model?.Clanovi ?? new List<NoviRacunClan>();

    var memberOptions = clanoviSrc
        .GroupBy(c => c.UserId)
        .Select(g => new
        {
            Value = g.Key,
            Label = !string.IsNullOrWhiteSpace(g.First().Nickname)
                ? $"{g.First().Nickname} ({g.First().Username})"
                : g.First().Username
        })
        .OrderBy(x => x.Label)
        .ToList();

    var initRows = clanoviSrc.Where(c => c.IsSelected).ToList();
    if (initRows.Count == 0) { initRows.Add(new NoviRacunClan()); }
}

<section class="app-hero">
    <h1>Novi račun</h1>
    <p>Dodaj račun i raspodeli iznos po učesnicima.</p>
</section>

<div class="app-card app-card-narrow">
    @if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
    {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form asp-action="NoviRacun" method="post" class="form-stacked">
        @Html.AntiForgeryToken()
        <input asp-for="GroupId" type="hidden" />

        <div class="form-field stretch">
            <label asp-for="Naziv" class="form-label">Naziv</label>
            <input asp-for="Naziv" class="input input-full" placeholder="npr. Pica i piće" autocomplete="off" />
            <span asp-validation-for="Naziv" class="field-validation"></span>
        </div>

        <div class="card-toolbar" style="margin-top:10px;">
            <h3 class="mt-0">Učesnici i iznosi</h3>
            <button type="button" id="addRow" class="btn btn-primary btn-sm">
                <i class="bx bx-plus"></i> Dodaj red
            </button>
        </div>

        <div class="table-wrap">
            <table class="bill-table edit members-table">
                <colgroup>
                    <col class="col-user" />
                    <col class="col-paid" />
                    <col class="col-share" />
                    <col class="col-actions" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Korisnik</th>
                        <th>Platio</th>
                        <th>Deo računa</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="rows" data-next-index="@initRows.Count">
                    @{
                        for (var i = 0; i < initRows.Count; i++)
                        {
                            var c = initRows[i];
                                <tr>
                                    <td>
                                        <input type="hidden" name="Clanovi.index" value="@i" />
                                        <select name="Clanovi[@i].UserId" class="input select pretty-select user-select">
                                            <option value="">— izaberi korisnika —</option>
                                        @foreach (var o in memberOptions)
                                        {
                                            if (c.UserId == o.Value)
                                            {
                                                            <option value="@o.Value" selected>@o.Label</option>
                                            }
                                            else
                                            {
                                                            <option value="@o.Value">@o.Label</option>
                                            }
                                        }
                                        </select>
                                        <input type="hidden" name="Clanovi[@i].IsSelected" value="true" />
                                    </td>
                                    <td>
                                        <input name="Clanovi[@i].Iznos" type="number" step="0.01" min="0"
                                               class="input" value="@(c.Iznos?.ToString("0.##"))" />
                                    </td>
                                    <td>
                                        <input name="Clanovi[@i].DeoRacuna" type="number" step="0.01" min="0"
                                               class="input" value="@(c.DeoRacuna?.ToString("0.##"))" />
                                    </td>
                                    <td class="tactions">
                                        <button type="button" class="btn btn-danger btn-sm removeRow" title="Ukloni red">
                                            <i class="bx bx-x"></i>
                                        </button>
                                    </td>
                                </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="form-actions">
            <a class="btn" asp-action="Racuni" asp-route-id="@Model.GroupId">
                <i class="bx bx-left-arrow-alt"></i> Otkaži
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="bx bx-save"></i> Sačuvaj
            </button>
        </div>
    </form>
</div>

<template id="row-template">
<tr>
    <td>
        <input type="hidden" name="Clanovi.index" value="__i__" />
        <select name="Clanovi[__i__].UserId" class="input select pretty-select user-select">
            <option value="">— izaberi korisnika —</option>
                @foreach (var o in memberOptions)
                {
                    <option value="@o.Value">@o.Label</option>
                }
        </select>
        <input type="hidden" name="Clanovi[__i__].IsSelected" value="true" />
    </td>
    <td><input name="Clanovi[__i__].Iznos" type="number" step="0.01" min="0" class="input" /></td>
    <td><input name="Clanovi[__i__].DeoRacuna" type="number" step="0.01" min="0" class="input" /></td>
    <td class="tactions">
        <button type="button" class="btn btn-danger btn-sm removeRow" title="Ukloni red"><i class="bx bx-x"></i></button>
    </td>
</tr>
</template>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', () => {
      const rowsEl = document.getElementById('rows');
      const addBtn  = document.getElementById('addRow');
      const tplHtml = document.getElementById('row-template').innerHTML.trim();

      function nextIndex() {
        const n = parseInt(rowsEl.dataset.nextIndex || '0', 10);
        rowsEl.dataset.nextIndex = (n + 1).toString();
        return n;
      }

      function refreshDuplicateLock() {
        const selects = rowsEl.querySelectorAll('.user-select');
        const chosen = new Set(Array.from(selects).map(s => s.value).filter(v => v));
        selects.forEach(s => {
          Array.from(s.options).forEach(opt => {
            if (!opt.value) return; 
            opt.disabled = chosen.has(opt.value) && s.value !== opt.value;
          });
        });
      }

      addBtn?.addEventListener('click', () => {
        const i = nextIndex();
        rowsEl.insertAdjacentHTML('beforeend', tplHtml.replaceAll('__i__', i));
        refreshDuplicateLock();
      });

      rowsEl?.addEventListener('click', (e) => {
        const btn = e.target.closest('.removeRow');
        if (!btn) return;
        btn.closest('tr')?.remove();
        refreshDuplicateLock();
      });

      rowsEl?.addEventListener('change', (e) => {
        if (e.target.matches('.user-select')) refreshDuplicateLock();
      });

      refreshDuplicateLock();
    });
    </script>
}
