@model SplitSync.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Unos koda i nova lozinka";
}
@section Styles {
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
        <link href="https://unpkg.com/[email protected]/css/boxicons.min.css" rel="stylesheet">
}
<div class="auth2 container forms forms-single">
    <section class="form signup">
        <header>Reset lozinke</header>

        <p class="desc">
            Unesite verifikacioni kod koji smo poslali na <b>@Model?.Email</b> i novu lozinku. Kod važi 15 minuta.
        </p>

        @if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
        {
            <div class="auth2-alert error">@Model.ErrorMessage</div>
        }

        <form asp-controller="Account" asp-action="ResetPassword" method="post" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" name="Email" value="@Model?.Email" />

            <div class="field input-field">
                <input type="text"
                       name="Code"
                       value="@Model?.Code"
                       inputmode="numeric"
                       pattern="[0-9]*"
                       class="input code-input"
                       autocomplete="one-time-code" />
            </div>

            <div class="field input-field">
                <input type="password"
                       id="Password"
                       name="Password"
                       value="@Model?.Password"
                       placeholder="Nova lozinka"
                       autocomplete="new-password" class="input" />
                <i class='bx bx-hide eye-icon' aria-hidden="true"></i>
            </div>

            <div class="field input-field">
                <input type="password"
                       id="ConfirmPassword"
                       name="ConfirmPassword"
                       value="@Model?.ConfirmPassword"
                       placeholder="Potvrdi lozinku"
                       autocomplete="new-password" class="input" />
                <i class='bx bx-hide eye-icon' aria-hidden="true"></i>
            </div>

            <div class="field">
                <button type="submit">Promeni lozinku</button>
            </div>

            <div class="form-link">
                <span>Niste dobili kod?</span>
                <a asp-action="ForgotPassword" asp-controller="Account">Pošalji novi kod</a>
            </div>

            <div class="form-link" style="margin-top:6px">
                <a asp-action="Login" asp-controller="Account">Vrati se na prijavu</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
        <script src="~/js/auth.js" asp-append-version="true"></script>
}